{
  "name": "vite-react-typescript-starter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently 'npm run start:py' 'nodemon -w src/server -x tsx src/server/main.ts'",
    "start": "NODE_ENV=production tsx src/server/main.ts",
    "build": "vite build",
    "build:css": "NODE_ENV=production tailwindcss build -i ./src/client/framework/index.css -o ./build/index.css --minify",
    "build:wheel": "cd src/client/framework/processing/py && poetry build --format wheel",
    "build:install-wheel": "cp -R src/client/framework/processing/py/dist/. ./public",
    "build:py": "npm run build:wheel && npm run build:install-wheel",
    "start:py": "nodemon --ext py --exec \"npm run build:py\""
  },
  "dependencies": {
    "@msgpack/msgpack": "^3.0.0-beta2",
    "@prisma/client": "^5.20.0",
    "@visx/responsive": "^3.10.2",
    "@visx/text": "^3.3.0",
    "@visx/wordcloud": "^3.3.0",
    "async-mutex": "^0.5.0",
    "concurrently": "^8.2.2",
    "express": "^4.18.2",
    "lottie-react": "^2.4.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-highlight-words": "^0.20.0",
    "react-router-dom": "^6.23.1",
    "recharts": "^2.12.7",
    "tsx": "^4.3.0",
    "typescript": "^5.3.2",
    "vite-express": "*",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.9.3",
    "@types/react": "^18.0.38",
    "@types/react-dom": "^18.2.16",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.19",
    "nodemon": "^3.0.1",
    "postcss": "^8.4.38",
    "prisma": "^5.20.0",
    "tailwindcss": "^3.4.4",
    "vite": "^5.0.2"
  }
}
